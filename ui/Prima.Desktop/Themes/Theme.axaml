<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Prima shared theme tokens. Every view pulls its colors and spacing from
       here; no screen defines its own one-off values. See CLAUDE.md >
       GUI conventions (consistent palette, reusable components). -->
  <Styles.Resources>
    <!-- Palette -->
    <Color x:Key="PrimaBackground">#1E1E23</Color>
    <Color x:Key="PrimaSurface">#2A2A31</Color>
    <Color x:Key="PrimaAccent">#4C8DFF</Color>
    <Color x:Key="PrimaText">#EDEDF0</Color>
    <!-- Stroke color for interactive drag handles drawn over the color wheel
         (hue-ring marker, SV-triangle marker). White reads clearly over any
         hue/saturation/value the handle sits on; a companion dark halo is drawn
         under it in code for contrast on light fills. -->
    <Color x:Key="PrimaHandleStroke">#FFFFFF</Color>

    <SolidColorBrush x:Key="PrimaBackgroundBrush" Color="{StaticResource PrimaBackground}" />
    <SolidColorBrush x:Key="PrimaSurfaceBrush" Color="{StaticResource PrimaSurface}" />
    <SolidColorBrush x:Key="PrimaAccentBrush" Color="{StaticResource PrimaAccent}" />
    <SolidColorBrush x:Key="PrimaTextBrush" Color="{StaticResource PrimaText}" />
    <SolidColorBrush x:Key="PrimaHandleStrokeBrush" Color="{StaticResource PrimaHandleStroke}" />

    <!-- Spacing (as Thickness so it can drive Padding/Margin directly) -->
    <Thickness x:Key="PrimaPadMedium">8</Thickness>
    <Thickness x:Key="PrimaPadLarge">16</Thickness>
  </Styles.Resources>

  <!-- Menu bar: Fluent's defaults are light-themed, so override to match
       the Prima dark palette. Any future top-level menu (Edit, View, ...)
       picks this up automatically since it targets the Menu/MenuItem types. -->
  <Style Selector="Menu">
    <Setter Property="Background" Value="{StaticResource PrimaSurfaceBrush}" />
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="Background" Value="{StaticResource PrimaSurfaceBrush}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaTextBrush}" />
  </Style>
  <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{StaticResource PrimaAccentBrush}" />
  </Style>
  <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{StaticResource PrimaAccentBrush}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource PrimaBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaTextBrush}" />
  </Style>
</Styles>
