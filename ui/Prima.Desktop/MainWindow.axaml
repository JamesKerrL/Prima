<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Prima.Desktop.MainWindow"
        Title="Prima" Width="820" Height="640"
        Background="{StaticResource PrimaBackgroundBrush}">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="{StaticResource PrimaSurfaceBrush}"
            Padding="{StaticResource PrimaPadMedium}">
      <TextBlock Text="Prima — drag on the canvas to paint"
                 Foreground="{StaticResource PrimaTextBrush}" />
    </Border>

    <Border Padding="{StaticResource PrimaPadLarge}">
      <Image x:Name="CanvasImage"
             Stretch="None"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
    </Border>
  </DockPanel>
</Window>
