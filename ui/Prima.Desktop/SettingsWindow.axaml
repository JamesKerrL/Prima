<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Prima.Desktop.SettingsWindow"
        Title="Settings"
        Width="420" Height="320"
        Background="{StaticResource PrimaBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="{StaticResource PrimaSurfaceBrush}"
            Padding="{StaticResource PrimaPadMedium}">
      <TextBlock Text="Settings" Foreground="{StaticResource PrimaTextBrush}" FontWeight="Bold" />
    </Border>

    <StackPanel Margin="{StaticResource PrimaPadLarge}" Spacing="8">
      <TextBlock Text="Window resolution" Foreground="{StaticResource PrimaTextBrush}" />
      <ComboBox x:Name="ResolutionComboBox"
                Width="220"
                HorizontalAlignment="Left"
                SelectionChanged="OnResolutionChanged">
        <ComboBoxItem>Fit to screen</ComboBoxItem>
        <ComboBoxItem>1280 x 720</ComboBoxItem>
        <ComboBoxItem>1600 x 900</ComboBoxItem>
        <ComboBoxItem>1920 x 1080</ComboBoxItem>
        <ComboBoxItem>2560 x 1440</ComboBoxItem>
      </ComboBox>

      <TextBlock Text="Storage" Foreground="{StaticResource PrimaTextBrush}" FontWeight="Bold" Margin="0,16,0,0" />
      <TextBlock Text="Palettes directory" Foreground="{StaticResource PrimaTextBrush}" />
      <DockPanel>
        <Button x:Name="OpenPalettesDirBtn" Content="Open in Explorer" DockPanel.Dock="Right" />
        <TextBox x:Name="PalettesDirText" IsReadOnly="True"
                 Foreground="{StaticResource PrimaTextBrush}"
                 Background="{StaticResource PrimaSurfaceBrush}" />
      </DockPanel>
    </StackPanel>
  </DockPanel>
</Window>
