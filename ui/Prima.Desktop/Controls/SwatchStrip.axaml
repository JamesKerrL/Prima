<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Prima.Desktop.Controls.SwatchStrip">
  <StackPanel Spacing="4">
    <Grid ColumnDefinitions="Auto,*">
      <TextBlock Text="Swatches" Foreground="{StaticResource PrimaTextBrush}" FontSize="11" VerticalAlignment="Center" />
      <Button x:Name="PART_PaletteMenu" Grid.Column="1"
              Content="▼"
              Background="Transparent"
              Foreground="{StaticResource PrimaTextBrush}"
              BorderThickness="0"
              FontSize="8"
              Padding="4,0"
              Margin="4,0,0,0"
              VerticalAlignment="Center"
              Click="OnPaletteMenuClick" />
    </Grid>
    <WrapPanel x:Name="PART_Swatches" />
    <TextBlock Text="History" Foreground="{StaticResource PrimaTextBrush}" FontSize="11" />
    <WrapPanel x:Name="PART_History" />
  </StackPanel>
</UserControl>
